# Local development: copy this file to .env.local and fill in your key.
#
# Render deployment:
#   Render Dashboard → service → Environment → Add:
#   Key:   ANTHROPIC_API_KEY
#   Value: sk-ant-api03-...
#   (declared as sync: false in render.yaml so it is set in the dashboard, never committed)
#
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
